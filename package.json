{
  "name": "@icco/robot.villas",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.2.2",
  "engines": {
    "node": ">=26"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint --fix src/ && pnpm fmt:yaml && pnpm typecheck",
    "fmt:yaml": "find . \\( -name '*.yml' -o -name '*.yaml' \\) -not -path './node_modules/*' -not -path './.next/*' -exec yq -iP '.' {} \\;",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "validate-feeds": "tsx scripts/validate-feeds.ts"
  },
  "dependencies": {
    "@fedify/fedify": "^2.2.3",
    "@fedify/next": "^2.2.3",
    "@fedify/postgres": "^2.2.3",
    "@fedify/vocab": "^2.2.3",
    "@google/genai": "^2.7.0",
    "@heroicons/react": "^2.2.0",
    "@icco/react-common": "^2026.10523.2",
    "@js-temporal/polyfill": "^0.5.1",
    "@logtape/logtape": "^2.1.1",
    "daisyui": "^5.5.20",
    "drizzle-orm": "^0.45.2",
    "escape-html": "^1.0.3",
    "js-yaml": "^4.1.1",
    "jsdom": "^29.1.1",
    "next": "^16.2.6",
    "postgres": "^3.4.9",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "rss-parser": "^3.13.0",
    "tailwindcss": "^4.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.6",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/escape-html": "^1.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.4.0",
    "postcss": "^8.5.15",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7"
  }
}
