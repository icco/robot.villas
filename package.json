{
  "name": "@icco/robot.villas",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint --fix src/ && yarn fmt:yaml",
    "fmt:yaml": "find . \\( -name '*.yml' -o -name '*.yaml' \\) -not -path './node_modules/*' -not -path './.next/*' -exec yq -iP '.' {} \\;",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@fedify/fedify": "^2.1.10",
    "@fedify/next": "^2.1.10",
    "@fedify/postgres": "^2.1.10",
    "@fedify/vocab": "^2.1.10",
    "@google/genai": "^1.49.0",
    "@heroicons/react": "^2.2.0",
    "@icco/react-common": "^2026.423.1",
    "@js-temporal/polyfill": "^0.5.1",
    "@logtape/logtape": "^2.0.2",
    "daisyui": "^5",
    "drizzle-orm": "^0.45.2",
    "escape-html": "^1.0.3",
    "js-yaml": "^4.1.0",
    "jsdom": "^29.0.2",
    "mastodon-widget": "^0.2.1",
    "next": "^16.2.4",
    "postgres": "^3.4.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "rss-parser": "^3.13.0",
    "tailwindcss": "^4",
    "zod": "^4.3.6"
  },
  "resolutions": {
    "esbuild": "^0.28.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.4",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@tailwindcss/postcss": "^4",
    "@types/escape-html": "^1.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.9",
    "eslint": "^10",
    "postcss": "^8.5.8",
    "tsx": "^4.19.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  }
}
